{
  "name": "trader-agent",
  "version": "0.1.0",
  "description": "Autonomous AI trading agent for Solana memecoins",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:ui": "cd ui && npm run dev",
    "build": "tsc -p tsconfig.json",
    "build:ui": "cd ui && npm run build",
    "start": "node dist/main.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "ai": "^4.0.0",
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.0",
    "bs58": "^6.0.0",
    "hono": "^4.0.0",
    "@hono/node-server": "^1.13.0",
    "grammy": "^1.30.0",
    "zod": "^3.22.0",
    "node-cron": "^3.0.0",
    "rss-parser": "^3.13.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/node-cron": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=22"
  }
}
